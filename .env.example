APP_HOST=0.0.0.0
APP_PORT=3000
BASE_PREFIX=/

# Public audience URL used by the QR code. Leave empty for the current URL.
VITE_PUBLIC_URL=
VITE_ROOM=planos-faliveis

# Optional Socket.IO multiplex endpoint, such as an ngrok URL.
VITE_SOCKET_ORIGIN=

# Used by multiplex_client/server.js.
MASTER_SECRET=replace-with-a-secret
PORT=3005
