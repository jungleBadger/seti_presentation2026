{
  "name": "ai_presentation",
  "version": "1.0.0",
  "main": "start.js",
  "scripts": {
    "start": "node start.js",
    "start:dev": "npm run build && concurrently \"npm run livereload:server\" \"npm run livereload:client\"",
    "livereload:server": "npx nodemon --config nodemon.json",
    "build": "vite build --config client/presentation_module/vite.config.mjs --mode production",
    "livereload:client": "vite serve --config client/presentation_module/vite.config.mjs --host",
    "lint": "npx eslint --fix --config eslint.config.mjs",
    "format": "prettier --write . --config .prettierrc.config.mjs",
    "test": "echo \"Error: no test specified\" && exit 0"
  },
  "authors": [
    "jungleBadger"
  ],
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/passport": "^3.0.2",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.1.3",
    "axios": "^1.17.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "reveal.js": "^5.2.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.5",
    "vue": "^3.5.18"
  }
}
